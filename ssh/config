# Defaults - allow agent keys (keychain) and prefer current agent socket
Host *
    IdentitiesOnly no

# GitHub - ED25519 key
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# Azure DevOps - RSA key
Host ssh.dev.azure.com
    HostName ssh.dev.azure.com
    User git
    IdentityFile ~/.ssh/id_rsa-4096
    IdentitiesOnly yes
