root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Two trailing spaces is CommonMark's hard line-break syntax, but 
# prose here isn't hard-wrapped and doesn't rely on that convention,
# so trim like everything else.
trim_trailing_whitespace = true

[Makefile]
indent_style = tab
