[user]
  name = Guillaume Cauchon
  email = gcauchon@gmail.com
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKjm6Owvzgxez9bBPxpS+uujtoYBsQ5sSWftIV+co37i

[core]
  autocrlf = input
  excludesfile = /Users/gcauchon/.gitignore_global
  editor = nvim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  line-numbers = true
  syntax-theme = OneDark

[diff]
  tool = tig
  verbosity = 5
  algorithm = histogram
  colorMoved = default

[init]
	defaultBranch = main

[merge]
  tool = diffmerge
  verbosity = 5
  conflictstyle = zdiff3

[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[alias]
  a = add --all
  c = commit --gpg-sign --message
  ca = commit --gpg-sign --amend
  cane = commit --gpg-sign --amend --no-edit
  s = status --untracked-files=all
  d = diff
  ds = diff --staged
  br = branch --verbose
  bl = branch --list
  bd = branch --delete
  bdf = branch --delete --force
  co = checkout
  cb = switch --create
  f = fetch
  fm = !git fetch --verbose && git merge --ff-only
  fp = fetch --prune
  m = merge --ff-only
  unstage = reset HEAD
  rollback = reset --soft HEAD^1
  r = rebase
  rc = rebase --continue
  rs = rebase --skip
  ra = rebase --abort
  p = push
  ph = push --set-upstream origin HEAD
  pf = push --force-with-lease --force-if-includes
  po = push origin

[pull]
	rebase = true

[push]
  autoSetupRemote = true

[fetch]
  prune = true

[rebase]
  autoStash = true
  autosquash = true

[rerere]
  enabled = true

[branch]
  sort = -committerdate

[column]
  ui = auto
