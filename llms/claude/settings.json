{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "SHELL": "/bin/zsh",
    "BASH_DEFAULT_TIMEOUT_MS": "120000"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(.claude/plans/*)",
      "Write(.claude/plans/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(mise *)",
      "Bash(tig*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue view*)",
      "Bash(gh run view*)",
      "Bash(gh api *)",
      "WebSearch",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:postgresql.org)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git pf)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(sudo *)",
      "Bash(curl * | sh*)",
      "Bash(wget * | sh*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit --amend*)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git checkout*)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/.claude/scripts/notify.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/.claude/scripts/fetch-usage.sh > /dev/null 2>&1 &"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (now | todate) + \"] \" + (.prompt // \"\")' >> ~/.claude/prompts.log && tail -n 5000 ~/.claude/prompts.log > ~/.claude/prompts.log.tmp && mv ~/.claude/prompts.log.tmp ~/.claude/prompts.log"
          },
          {
            "type": "command",
            "command": "sh $HOME/.claude/scripts/fetch-usage.sh > /dev/null 2>&1 &"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // .tool_input.path // \"\"'); echo \"$fp\" | grep -qE '(^|/)\\.git/|node_modules/|\\.lock$|\\.pyc$' && { echo \"Editing '$fp' is blocked by policy. This is a generated or managed file.\" >&2; exit 2; } || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // empty'); if [ -n \"$fp\" ] && echo \"$fp\" | grep -qE '\\.(sh|bash|zsh)$'; then shellcheck \"$fp\" 2>&1; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (now | todate) + \"] \" + .tool_input.command' >> ~/.claude/bash-commands.log && tail -n 10000 ~/.claude/bash-commands.log > ~/.claude/bash-commands.log.tmp && mv ~/.claude/bash-commands.log.tmp ~/.claude/bash-commands.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/.claude/scripts/fetch-usage.sh > /dev/null 2>&1 &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/scripts/status-line.sh"
  },
  "enabledPlugins": {
    "umano-connect@umano-medical-plugins": true,
    "umano-medical@umano-medical-plugins": true
  },
  "extraKnownMarketplaces": {
    "umano-medical-plugins": {
      "source": {
        "source": "github",
        "repo": "umano-medical/umano-ai-workflows"
      }
    }
  },
  "effortLevel": "high",
  "plansDirectory": ".claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "theme": "auto",
  "editorMode": "normal",
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": false,
  "showTurnDuration": true,
  "noBanner": true,
  "autoUpdatesChannel": "latest"
}
