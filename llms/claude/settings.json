{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "SHELL": "/bin/zsh",
    "BASH_DEFAULT_TIMEOUT_MS": "120000"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(.claude/plans/*)",
      "Write(.claude/plans/*)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(mise *)",
      "Bash(tig *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh issue view *)",
      "Bash(gh run view *)",
      "Bash(gh api *)",
      "WebSearch",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:postgresql.org)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git pf)",
      "Bash(git reset --hard*)",
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ],
    "ask": [
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opusplan",
  "outputStyle": "voice-and-format",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // .tool_input.path // \"\"'); echo \"$fp\" | grep -qE '(^|/)\\.git/|node_modules/|\\.lock$' && { echo \"Editing '$fp' is blocked by policy. This is a generated or managed file.\" >&2; exit 2; } || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // empty'); command -v shellcheck >/dev/null 2>&1 || exit 0; if [ -n \"$fp\" ] && echo \"$fp\" | grep -qE '\\.(sh|bash)$'; then findings=$(shellcheck --severity=warning \"$fp\" 2>&1); if [ -n \"$findings\" ]; then echo \"$findings\" >&2; exit 2; fi; fi; exit 0"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/scripts/status-line.sh"
  },
  "enabledPlugins": {
    "umano-connect@umano-medical-plugins": true,
    "umano-medical@umano-medical-plugins": true
  },
  "extraKnownMarketplaces": {
    "umano-medical-plugins": {
      "source": {
        "source": "github",
        "repo": "umano-medical/connect-ai-workflows"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "plansDirectory": ".claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "showTurnDuration": true,
  "sandbox": {
    "enabled": true,
    "credentials": {
      "files": [
        { "path": "~/.ssh", "mode": "deny" },
        { "path": "~/.aws/credentials", "mode": "deny" },
        { "path": "~/.claude/.credentials.json", "mode": "deny" }
      ]
    }
  }
}
