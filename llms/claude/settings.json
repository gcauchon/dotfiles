{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "model": "opusplan",
  "env": {
    "SHELL": "/bin/zsh",
    "BASH_DEFAULT_TIMEOUT_MS": "120000"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/fetch-usage.sh > /dev/null 2>&1 &"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); [[ $cmd =~ \\bpip3?\\b ]] && { echo 'This environment uses uv, not pip. Use \"uv pip install\" or \"uv add\" instead.' >&2; exit 2; }"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // .tool_input.path // \"\"'); [[ $fp =~ (^|/)\\.git/|node_modules/|\\.lock$|\\.pyc$ ]] && { echo \"Editing '$fp' is blocked by policy. This is a generated or managed file.\" >&2; exit 2; }"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // empty'); [[ -n $fp && $fp =~ \\.(sh|bash|zsh)$ ]] && { shellcheck \"$fp\" 2>&1 || true; }"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (now | todate) + \"] \" + .tool_input.command' >> ~/.claude/bash-commands.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/fetch-usage.sh > /dev/null 2>&1 &"
          },
          {
            "type": "prompt",
            "model": "haiku",
            "prompt": "Review the assistant's final response. Reject if the assistant is rationalizing incomplete work. Patterns to catch: claiming issues are 'pre-existing' or 'out of scope' to avoid fixing them, deferring work to a 'follow-up' that was not requested, listing problems without fixing them and calling that done, skipping test or lint failures with excuses. If any pattern matches, respond {\"decision\": \"block\", \"reason\": \"You are rationalizing incomplete work. [specific issue]. Go back and finish.\"}. If work is genuinely complete, respond {\"decision\": \"allow\"}."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(brew *)",
      "Bash(uv *)",
      "Bash(mise *)",
      "Bash(docker compose *)",
      "Bash(make *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(sudo *)",
      "Read(**/.env)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline.sh"
  },
  "plansDirectory": ".claude/plans",
  "noBanner": true,
  "autoUpdateChannel": "stable",
  "showTurnDuration": true
}